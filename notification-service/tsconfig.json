{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "noImplicitAny": false,
    "lib": ["es2021"],
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
    "outDir": "dist"
  },
  "include": [
    "index.ts",
    "src/**/*",
    "../shared/**/*"
  ],
  "exclude": ["node_modules"]
}