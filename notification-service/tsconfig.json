{
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "noImplicitAny": false,
    "lib": [
      "es2021"
    ],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
  },
  "include": [
    "notification-service/index.ts",
    "notification-service/src/**/*",
    "shared/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}