{
    "compilerOptions": {
        "target": "es2020",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "es2021"
        ],
        "strict": false,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "dist",
        "rootDir": "./",
        "allowJs": true
    },
    "include": [
        "index.ts",
        "src/**/*",
        "models/**/*",
        "config/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}